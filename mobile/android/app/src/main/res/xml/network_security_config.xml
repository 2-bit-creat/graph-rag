<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow HTTP to local backend during dev (emulator + LAN Wi-Fi). -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
