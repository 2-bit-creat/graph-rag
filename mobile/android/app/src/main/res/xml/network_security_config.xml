<?xml version="1.0" encoding="utf-8"?>
<!-- Release/profile default: HTTPS only. Cleartext HTTP is blocked so a
     production build can never talk to the backend over an unencrypted link.
     The debug build overrides this with a permissive config
     (src/debug/res/xml/network_security_config.xml) for localhost/LAN dev. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
