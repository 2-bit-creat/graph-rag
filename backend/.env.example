# PostgreSQL connection (async driver).
DATABASE_URL=postgresql+asyncpg://graphrag:graphrag@localhost:6432/graphrag

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_PREMIUM_MODEL=gpt-4o

# Deployment environment: "development" (default) or "production".
# In production, token-less requests are rejected with 401 (no dev-user
# fallback) and the server refuses to boot on the placeholder JWT_SECRET below.
ENVIRONMENT=development

# Auth — MUST set a long random JWT_SECRET before ENVIRONMENT=production.
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRE_MINUTES=10080

# CORS: Flutter web / mobile dev origins
CORS_ORIGINS=http://localhost:8080

# Storage
UPLOAD_DIR=./uploads
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=ap-northeast-2

# Pipeline performance
DEBUG_RUNS_DIR=./debug_runs
GRAPH_BACKGROUND=false
GRAPH_MANUAL_ONLY=true
AUDIO_TRIM_ENABLED=true
AUDIO_TRIM_MODE=edges
AUDIO_TRIM_SKIP_WHEN_DIARIZATION=true
JOURNAL_SKIP_ENTITY_REFINEMENT=true

# Optional speaker diarization (Deepgram — Whisper does not diarize)
SPEAKER_DIARIZATION_ENABLED=false
DEEPGRAM_API_KEY=
# Local diarization fallback (https://huggingface.co/pyannote/speaker-diarization-3.1)
PYANNOTE_HF_TOKEN=

# When Deepgram/pyannote collapse multiple voices into one label, split via embeddings
SPEAKER_REFINEMENT_ENABLED=true
SPEAKER_REFINEMENT_THRESHOLD=0.55
SPEAKER_REFINEMENT_MIN_DURATION_SEC=4.0
SPEAKER_REFINEMENT_SAME_SPEAKER_SIM_CAP=0.85

# Voice memory
SPEAKER_VOICE_MEMORY_ENABLED=true
SPEAKER_EMBEDDING_BACKEND=spectral
SPEAKER_MATCH_THRESHOLD=0.85
SPEAKER_AUTO_CONFIRM_THRESHOLD=0.92

# Celery / Redis
REDIS_URL=redis://localhost:6379/0
GRAPH_PROCESSING_ASYNC=false

# Hybrid RAG
HYBRID_WEIGHT=0.6
FREE_TIER_QUIZ_LIMIT=3
FREE_TIER_REVIEW_DAYS=7
