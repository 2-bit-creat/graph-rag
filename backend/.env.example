# PostgreSQL connection (async driver).
# Local docker-compose default below. For Supabase, swap in the pooled
# connection string and keep the +asyncpg driver suffix.
DATABASE_URL=postgresql+asyncpg://graphrag:graphrag@localhost:5432/graphrag

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# CORS: comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000
